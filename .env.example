# Emotions-System 环境变量配置

# ========== LLM 服务配置 ==========
LLM_API_KEY=your_openai_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# ========== 阿里百炼 DashScope 配置 ==========
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ========== TTS 服务配置 ==========
TTS_MODEL=cosyvoice-v2
TTS_DEFAULT_VOICE=longxiaochun

# ========== 声音复刻配置 ==========
VOICE_CONFIG_PATH=data/voice_configs.json

# ========== 服务器配置 ==========
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WS_PATH=/ws
