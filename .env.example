# Emotions-System 环境变量配置
# 复制本文件为 .env 并填入实际值：
#   Linux/macOS: cp .env.example .env
#   Windows CMD: copy .env.example .env
#   Windows PowerShell: Copy-Item .env.example .env

# ========== LLM 服务配置 ==========
# 后端类型：openai（OpenAI 兼容 API）或 ark（字节火山引擎 Ark SDK）
LLM_BACKEND=ark
# Ark 后端：填写火山引擎 API Key；OpenAI 后端：填写 OpenAI API Key
LLM_API_KEY=your_api_key_here
# Ark 后端：填写 Endpoint ID（如 ep-xxxxxxx）；OpenAI 后端：填写模型名（如 gpt-4）
LLM_MODEL=your_model_or_endpoint_id_here
# OpenAI 后端专用：API Base URL（Ark 后端无需设置）
LLM_BASE_URL=https://api.openai.com/v1
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# ========== 阿里百炼 DashScope 配置 ==========
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ========== TTS 服务配置 ==========
# 推荐使用 cosyvoice-v1（支持 instruction 情感指令控制，性价比最高）
# 可选：cosyvoice-v1, cosyvoice-v2, cosyvoice-v3-flash, cosyvoice-v3-plus, cosyvoice-v3.5-flash, cosyvoice-v3.5-plus
# 注意：v3.5 系列没有系统音色，需要先复刻音色后才能使用
TTS_MODEL=cosyvoice-v1
TTS_DEFAULT_VOICE=longxiaochun

# ========== 声音复刻配置 ==========
VOICE_CONFIG_PATH=data/voice_configs.json

# ========== 服务器配置 ==========
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WS_PATH=/ws
